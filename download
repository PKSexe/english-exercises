<!DOCTYPE html>
<html lang="zh-TW">
<head>
  <meta charset="UTF-8">
  <meta name="viewport" content="width=device-width, initial-scale=1.0">
  <title>📚 英文練習下載系統</title>
  <style>
    * {
      margin: 0;
      padding: 0;
      box-sizing: border-box;
    }

    body {
      font-family: 'Segoe UI', Tahoma, Geneva, Verdana, sans-serif;
      background: linear-gradient(135deg, #667eea 0%, #764ba2 100%);
      min-height: 100vh;
      display: flex;
      align-items: center;
      justify-content: center;
      padding: 20px;
    }

    .container {
      background: white;
      border-radius: 24px;
      box-shadow: 0 25px 50px rgba(0,0,0,0.15);
      padding: 45px;
      max-width: 520px;
      width: 100%;
      animation: slideIn 0.8s cubic-bezier(0.25, 0.46, 0.45, 0.94);
    }

    @keyframes slideIn {
      from {
        opacity: 0;
        transform: translateY(40px) scale(0.95);
      }
      to {
        opacity: 1;
        transform: translateY(0) scale(1);
      }
    }

    .header {
      text-align: center;
      margin-bottom: 35px;
    }

    .header-icon {
      font-size: 64px;
      margin-bottom: 15px;
    }

    .header h1 {
      color: #1a1a1a;
      font-size: 32px;
      font-weight: 800;
      margin-bottom: 8px;
      background: linear-gradient(135deg, #667eea, #764ba2);
      -webkit-background-clip: text;
      -webkit-text-fill-color: transparent;
      background-clip: text;
    }

    .header p {
      color: #6b7280;
      font-size: 16px;
      line-height: 1.5;
    }

    .form-group {
      margin-bottom: 28px;
    }

    .form-row {
      display: grid;
      grid-template-columns: 1fr 1fr;
      gap: 18px;
      margin-bottom: 20px;
    }

    label {
      display: block;
      margin-bottom: 10px;
      color: #374151;
      font-weight: 600;
      font-size: 15px;
    }

    select, input[type="email"], input[type="text"] {
      width: 100%;
      padding: 16px 20px;
      border: 2px solid #e5e7eb;
      border-radius: 16px;
      font-size: 16px;
      transition: all 0.3s cubic-bezier(0.4, 0, 0.2, 1);
      background: #fafbfc;
      appearance: none;
    }

    select {
      background-image: url("data:image/svg+xml,%3csvg xmlns='http://www.w3.org/2000/svg' fill='none' viewBox='0 0 20 20'%3e%3cpath stroke='%236b7280' stroke-linecap='round' stroke-linejoin='round' stroke-width='1.5' d='m6 8 4 4 4-4'/%3e%3c/svg%3e");
      background-position: right 12px center;
      background-repeat: no-repeat;
      background-size: 18px;
      padding-right: 50px;
    }

    select:focus, input:focus {
      outline: none;
      border-color: #667eea;
      background: white;
      box-shadow: 0 0 0 4px rgba(102, 126, 234, 0.1);
      transform: translateY(-1px);
    }

    .auth-section {
      background: linear-gradient(135deg, #f8fafc, #f1f5f9);
      border: 1px solid #e2e8f0;
      border-radius: 16px;
      padding: 24px;
      margin-bottom: 28px;
    }

    .auth-section h3 {
      color: #1e293b;
      font-size: 18px;
      font-weight: 700;
      margin-bottom: 12px;
    }

    .auth-section p {
      color: #64748b;
      font-size: 14px;
      margin-bottom: 16px;
    }

    .submit-btn {
      width: 100%;
      padding: 20px;
      background: linear-gradient(135deg, #667eea 0%, #764ba2 100%);
      color: white;
      border: none;
      border-radius: 16px;
      font-size: 18px;
      font-weight: 700;
      cursor: pointer;
      transition: all 0.3s cubic-bezier(0.4, 0, 0.2, 1);
      position: relative;
      overflow: hidden;
    }

    .submit-btn:hover {
      transform: translateY(-3px);
      box-shadow: 0 20px 40px rgba(102, 126, 234, 0.4);
    }

    .submit-btn:active {
      transform: translateY(-1px);
    }

    .submit-btn:disabled {
      opacity: 0.7;
      cursor: not-allowed;
      transform: none;
    }

    .submit-btn .loading {
      display: inline-block;
      width: 20px;
      height: 20px;
      border: 2px solid rgba(255,255,255,0.3);
      border-top: 2px solid white;
      border-radius: 50%;
      animation: spin 1s linear infinite;
      margin-right: 12px;
    }

    @keyframes spin {
      0% { transform: rotate(0deg); }
      100% { transform: rotate(360deg); }
    }

    .response {
      margin-top: 24px;
      padding: 20px;
      border-radius: 16px;
      text-align: center;
      font-weight: 600;
      display: none;
      animation: fadeIn 0.3s ease;
    }

    .response.success {
      background: linear-gradient(135deg, #dcfce7, #bbf7d0);
      color: #166534;
      border: 1px solid #86efac;
    }

    .response.error {
      background: linear-gradient(135deg, #fef2f2, #fecaca);
      color: #dc2626;
      border: 1px solid #fca5a5;
    }

    @keyframes fadeIn {
      from { opacity: 0; transform: translateY(10px); }
      to { opacity: 1; transform: translateY(0); }
    }

    @media (max-width: 600px) {
      .form-row {
        grid-template-columns: 1fr;
        gap: 16px;
      }
      
      .container {
        padding: 35px 25px;
        margin: 10px;
      }
      
      .header h1 {
        font-size: 28px;
      }
      
      .auth-section {
        padding: 20px;
      }
    }

    .footer {
      text-align: center;
      margin-top: 30px;
      padding-top: 20px;
      border-top: 1px solid #e5e7eb;
      color: #9ca3af;
      font-size: 14px;
    }
  </style>
</head>
<body>
  <div class="container">
    <div class="header">
      <div class="header-icon">📚</div>
      <h1>英文練習下載系統</h1>
      <p>請選擇課本資料並輸入老師提供的認證碼，即可下載對應練習</p>
    </div>

    <form id="exerciseForm">
      <!-- 出版社與年級 -->
      <div class="form-row">
        <div class="form-group">
          <label for="publisher">📖 出版社</label>
          <select name="publisher" id="publisher" required>
            <option value="">請選擇出版社</option>
            <option value="Oxford">Oxford</option>
            <option value="Longman">Longman</option>
            <option value="EPH">EPH</option>
            <option value="Aristo">Aristo</option>
            <option value="Ling Kee">Ling Kee</option>
          </select>
        </div>
        <div class="form-group">
          <label for="grade_level">📊 年級</label>
          <select name="grade_level" id="grade_level" required>
            <option value="">請選擇年級</option>
            <option value="P.1">P.1</option>
            <option value="P.2">P.2</option>
            <option value="P.3">P.3</option>
            <option value="P.4">P.4</option>
            <option value="P.5">P.5</option>
            <option value="P.6">P.6</option>
          </select>
        </div>
      </div>

      <!-- 章數 -->
      <div class="form-group">
        <label for="unit">📑 章數 / 單元</label>
        <select name="unit" id="unit" required>
          <option value="">請選擇章數</option>
          <option value="Unit 1">Unit 1</option>
          <option value="Unit 2">Unit 2</option>
          <option value="Unit 3">Unit 3</option>
          <option value="Unit 4">Unit 4</option>
          <option value="Unit 5">Unit 5</option>
          <option value="Unit 6">Unit 6</option>
          <option value="Unit 7">Unit 7</option>
          <option value="Unit 8">Unit 8</option>
          <option value="Unit 9">Unit 9</option>
          <option value="Unit 10">Unit 10</option>
          <option value="Unit 11">Unit 11</option>
          <option value="Unit 12">Unit 12</option>
          <option value="Unit 13">Unit 13</option>
          <option value="Unit 14">Unit 14</option>
          <option value="Unit 15">Unit 15</option>
          <option value="Unit 16">Unit 16</option>
          <option value="Unit 17">Unit 17</option>
          <option value="Unit 18">Unit 18</option>
          <option value="Unit 19">Unit 19</option>
          <option value="Unit 20">Unit 20</option>
          <option value="Unit 21">Unit 21</option>
          <option value="Unit 22">Unit 22</option>
          <option value="Unit 23">Unit 23</option>
          <option value="Unit 24">Unit 24</option>
          <option value="Unit 25">Unit 25</option>
          <option value="Unit 26">Unit 26</option>
          <option value="Unit 27">Unit 27</option>
          <option value="Unit 28">Unit 28</option>
          <option value="Unit 29">Unit 29</option>
          <option value="Unit 30">Unit 30</option>
        </select>
      </div>

      <!-- Email -->
      <div class="form-group">
        <label for="email">📧 收件電郵</label>
        <input type="email" name="email" id="email" placeholder="student@example.com" required>
      </div>

      <!-- 認證碼 -->
      <div class="auth-section">
        <h3>🔐 認證碼驗證</h3>
        <p>請輸入老師或學校提供的<strong>一次性認證碼</strong>，每個碼只能使用一次</p>
        <div class="form-group">
          <label for="auth_code">一次性認證碼</label>
          <input type="text" name="auth_code" id="auth_code" placeholder="例如：AUTH-202603-ABCD" required>
        </div>
      </div>

      <button type="submit" class="submit-btn" id="submitBtn">
        🚀 立即下載練習
      </button>
    </form>

    <div id="response" class="response"></div>

    <div class="footer">
      <p>由 Make.com 自動化系統提供 • 安全 • 快速</p>
    </div>
  </div>

  <script>
    const form = document.getElementById('exerciseForm');
    const submitBtn = document.getElementById('submitBtn');
    const responseDiv = document.getElementById('response');

    // 設定你的 Make.com Webhook URL
    const WEBHOOK_URL = 'https://hook.us2.make.com/v695caqqr5yenn1xpdb0bojvok2jbxmn';

    form.addEventListener('submit', async function(e) {
      e.preventDefault();
      
      // 驗證必填欄位
      if (!form.checkValidity()) {
        showResponse('請填妥所有欄位', 'error');
        return;
      }

      // 顯示載入狀態
      submitBtn.disabled = true;
      submitBtn.innerHTML = '<span class="loading"></span>處理中，請稍候...';
      responseDiv.style.display = 'none';

      try {
        const formData = new FormData(form);
        
        const response = await fetch(WEBHOOK_URL, {
          method: 'POST',
          body: formData
        });

        const result = await response.text();
        
        if (response.ok) {
          showResponse('✅ 成功！練習檔已發送到您的電郵，請查收（垃圾郵件夾請留意）', 'success');
          form.reset();
        } else {
          showResponse(result || '處理失敗，請稍後再試或聯絡老師', 'error');
        }
      } catch (error) {
        showResponse('網路連線錯誤，請檢查網路後重試', 'error');
        console.error('Error:', error);
      } finally {
        // 恢復按鈕
        submitBtn.disabled = false;
        submitBtn.innerHTML = '🚀 立即下載練習';
      }
    });

    function showResponse(message, type) {
      responseDiv.textContent = message;
      responseDiv.className = `response ${type}`;
      responseDiv.style.display = 'block';
      
      // 自動隱藏錯誤訊息
      if (type === 'error') {
        setTimeout(() => {
          responseDiv.style.display = 'none';
        }, 8000);
      }
    }
  </script>
</body>
</html>
